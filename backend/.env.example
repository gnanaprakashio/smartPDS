PORT=5000

# Schedule Configuration
# Days to delay collection date after stock upload (default: 2 days)
# Example: Stock uploaded Monday → Collection Wednesday
SCHEDULE_DELAY_DAYS=2

# Skip Sundays (true/false) - Sunday is holiday for PDS
SCHEDULE_SKIP_SUNDAY=true

# WhatsApp Business API (optional - leave blank for simulated messages)
# Get from: https://developers.facebook.com/
WHATSAPP_TOKEN="your_whatsapp_access_token"
PHONE_NUMBER_ID="your_phone_number_id"

# Twilio SMS API (optional - leave blank for simulated SMS)
# Sign up at https://www.twilio.com/
# Get your Account SID, Auth Token, and Twilio phone number
TWILIO_ACCOUNT_SID="your_twilio_sid_here"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="your_twilio_phone_number_here"